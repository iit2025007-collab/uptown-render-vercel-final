PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CLIENT_URLS=
ALLOW_VERCEL_PREVIEWS=true
JWT_SECRET=replace_with_a_long_random_secret

# Local test: leave MONGODB_URI empty to use backend/data/local-db.json.
# Real deployment: paste your MongoDB Atlas connection string here.
MONGODB_URI=

# Gmail OTP mail setup
REQUIRE_EMAIL_OTP=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_16_character_google_app_password_without_spaces
MAIL_FROM=Uptown <yourgmail@gmail.com>

# Google login
GOOGLE_CLIENT_ID=

# Razorpay checkout/paywall
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
